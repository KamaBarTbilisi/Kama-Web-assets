  "faqs": [
    {
      "id": "m4vlv0p34",
      "order": 0,
      "en": {
        "question": "How do I order?",
        "answer": "You can order directly through our delivery partners: Wolt, Glovo, and Bolt Food. Simply search for \"Kama\" on your preferred app."
      },
      "ka": {
        "question": "როგორ შევუკვეთო?",
        "answer": "შეკვეთა შეგიძლიათ ჩვენი პარტნიორი პლატფორმების საშუალებით: Wolt, Glovo და Bolt Food. უბრალოდ ჩაწერეთ \"კამა\" საძიებო ველში."
      }
    },
    {
      "id": "zksqyslhu",
      "order": 1,
      "en": {
        "question": "Where are you located?",
        "answer": "Our physical bar is located at 5 Niko Nikoladze St., Tbilisi. Stop by for a fresh bowl and a quick healthy break!"
      },
      "ka": {
        "question": "სად მდებარეობთ?",
        "answer": "ჩვენი ფილიალი მდებარეობს თბილისში, ნიკო ნიკოლაძის ქუჩა 5-ში. გვეწვიეთ ჯანსაღი ლანჩისთვის."
      }
    },
    {
      "id": "as8e3ng4e",
      "order": 2,
      "en": {
        "question": "Do you provide nutritional information?",
        "answer": "Yes. Every item in our menu includes a full breakdown of calories, protein, fats, and carbohydrates to help you track your goals."
      },
      "ka": {
        "question": "მითითებულია თუ არა კერძების კალორიულობა?",
        "answer": "დიახ. ჩვენი მენიუს თითოეულ პოზიციას ახლავს დეტალური ინფორმაცია: კალორიები, ცილები, ცხიმები და ნახშირწყლები."
      }
    },
    {
      "id": "xat8nrxwj",
      "order": 3,
      "en": {
        "question": "Are your ingredients fresh?",
        "answer": "Absolutely. We source our vegetables daily and prepare our signature dressings in-house to ensure maximum nutritional value and taste."
      },
      "ka": {
        "question": "ინგრედიენტები ყოველდღიურად ახლდება?",
        "answer": "რა თქმა უნდა. ბოსტნეულს ყოველდღე ვარჩევთ, სოუსებს კი თავად ვამზადებთ, რათა შევინარჩუნოთ პროდუქტის მაქსიმალური კვებითი ღირებულება."
      }
    },
    {
      "id": "slh0qmedq",
      "order": 4,
      "en": {
        "question": "Do you have vegan or vegetarian options?",
        "answer": "Yes! We offer a variety of plant-based bowls, such as our Super Veggie Salad, designed to be both filling and nutrient-dense."
      },
      "ka": {
        "question": "გაქვთ ვეგანური ან ვეგეტარიანული კერძები?",
        "answer": "დიახ! ჩვენ გთავაზობთ მრავალფეროვან მცენარეულ ბოულებს, მაგალითად სუპერ ვეჯი სალათს, რომელიც ნოყიერი და სასარგებლოა."
      }
    },
    {
      "id": "8dc3freb4",
      "order": 5,
      "en": {
        "question": "Can I customize my bowl?",
        "answer": "We offer chef-crafted combinations for the best flavor balance, but you can always check our delivery apps for available add-ons and modifications."
      },
      "ka": {
        "question": "შესაძლებელია თუ არა ბოულის მოდიფიკაცია?",
        "answer": "ჩვენ გთავაზობთ შეფ-მზარეულის მიერ დაბალანსებულ კომბინაციებს, თუმცა დამატებითი ინგრედიენტების არჩევა ყოველთვის შეგიძლიათ საოპერაციო პლატფორმებზე."
      }
